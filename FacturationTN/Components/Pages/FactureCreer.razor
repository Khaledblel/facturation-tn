@page "/factures/creer"
@page "/factures/editer/{id:int}"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using FacturationTN.Models
@using FacturationTN.Models.Enums
@using FacturationTN.Services.Interfaces

@inject IClientService ClientService
@inject IProduitService ProduitService
@inject IFactureService FactureService
@inject IParametresService ParametresService
@inject NavigationManager NavigationManager

<PageTitle>@(Id.HasValue ? "Modifier facture" : "Nouvelle facture")</PageTitle>

<div class="facture-create-shell">
<section class="facture-create-hero mb-4">
    <div class="facture-create-hero-inner">
        <div>
            <p class="facture-create-eyebrow mb-2">Cycle de facturation</p>
            <h1 class="mb-2 facture-create-title">@(Id.HasValue ? "Modifier la facture" : "Nouvelle facture")</h1>
            <p class="mb-0 facture-create-subtitle">Préparez les lignes, vérifiez les montants et enregistrez en brouillon.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap justify-content-lg-end">
            <a class="btn btn-outline-light facture-create-hero-btn" href="/factures">Retour à la liste</a>
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(summaryMessage))
{
    <div class="alert @(summaryIsError ? "alert-danger" : "alert-success") facture-create-alert" role="alert">
        @summaryMessage
    </div>
}

@* ── Invoice Header ───────────────────────────────────────────── *@
<div class="card border-0 shadow-sm facture-create-card mb-3">
    <div class="card-header bg-white fw-semibold facture-create-card-header">Entête facture</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label facture-create-label">N° Facture</label>
                <input type="text" class="form-control facture-create-readonly" readonly value="@numeroFacture" />
                <div class="form-text">Généré automatiquement</div>
            </div>
            <div class="col-md-4">
                <label class="form-label facture-create-label">Date <span class="text-danger">*</span></label>
                <input type="date" class="form-control" @bind="dateFacture" />
            </div>
            <div class="col-md-4">
                <label class="form-label facture-create-label">Client <span class="text-danger">*</span></label>
                <select class="form-select" @bind="selectedClientId">
                    <option value="">— Sélectionner un client —</option>
                    @foreach (var c in clients)
                    {
                        <option value="@c.Id">@c.Nom</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

@* ── Line Items ───────────────────────────────────────────────── *@
<div class="card border-0 shadow-sm facture-create-card mb-3">
    <div class="card-header bg-white d-flex justify-content-between align-items-center facture-create-card-header">
        <span class="fw-semibold">Lignes de facture</span>
        <button class="btn btn-primary btn-sm facture-create-add-line" @onclick="AddLine">
            + Ajouter une ligne
        </button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0 facture-create-table">
                <thead>
                    <tr>
                        <th style="min-width: 200px;">Produit</th>
                        <th>Désignation</th>
                        <th class="text-center" style="width: 100px;">Qté</th>
                        <th class="text-end" style="width: 130px;">PU HT</th>
                        <th class="text-center" style="width: 90px;">TVA %</th>
                        <th class="text-end" style="width: 140px;">Montant HT</th>
                        <th class="text-center" style="width: 60px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (lignes.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4 facture-create-empty">
                                Aucune ligne. Cliquez sur <strong>Ajouter une ligne</strong> pour commencer.
                            </td>
                        </tr>
                    }
                    @for (int i = 0; i < lignes.Count; i++)
                    {
                        var index = i;
                        var ligne = lignes[index];
                        <tr>
                            <td>
                                <select class="form-select form-select-sm" @bind="ligne.ProduitId"
                                        @bind:after="() => OnProduitChanged(index)">
                                    <option value="">— Produit —</option>
                                    @foreach (var p in produits)
                                    {
                                        <option value="@p.Id">@p.Reference — @p.Designation</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <input type="text"
                                       class="form-control form-control-sm facture-create-readonly"
                                       @bind="ligne.Designation"
                                       @bind:event="oninput" />
                            </td>
                            <td>
                                <input type="number" class="form-control form-control-sm text-center" min="1"
                                       @bind="ligne.Quantite" @bind:event="oninput" />
                            </td>
                            <td class="text-end">
                                <span class="small">@ligne.PrixUnitaireHT.ToString("N3") TND</span>
                            </td>
                            <td class="text-center">
                                <span class="badge facture-create-tva-badge @GetTvaBadgeClass(ligne.TauxTva)">@ligne.TauxTva %</span>
                            </td>
                            <td class="text-end fw-semibold">
                                @ligne.MontantHT.ToString("N3") TND
                            </td>
                            <td class="text-center">
                                <button class="btn btn-sm facture-create-delete-line" @onclick="() => RemoveLine(index)" title="Supprimer la ligne">
                                    <svg class="facture-create-delete-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                        <path d="M5 7H19" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path>
                                        <path d="M9 7V5.8C9 5.36 9.36 5 9.8 5H14.2C14.64 5 15 5.36 15 5.8V7" stroke="currentColor" stroke-width="1.7"></path>
                                        <path d="M8 9.5V18C8 18.55 8.45 19 9 19H15C15.55 19 16 18.55 16 18V9.5" stroke="currentColor" stroke-width="1.7"></path>
                                    </svg>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ── Récapitulatif (Totals) ───────────────────────────────────── *@
<div class="row justify-content-end mb-4">
    <div class="col-12 col-lg-6 col-xl-5">
        <div class="card border-0 shadow-sm facture-create-card facture-create-totals-card">
            <div class="card-header bg-white fw-semibold facture-create-card-header">Récapitulatif</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0 facture-create-totals-table">
                    <tbody>
                        <tr>
                            <td class="ps-3">Total HT</td>
                            <td class="text-end pe-3 fw-semibold">@TotalHT.ToString("N3") TND</td>
                        </tr>
                        @foreach (var tva in TvaBreakdown)
                        {
                            <tr>
                                <td class="ps-3 text-muted">TVA @tva.Taux %</td>
                                <td class="text-end pe-3">@tva.Montant.ToString("N3") TND</td>
                            </tr>
                        }
                        <tr>
                            <td class="ps-3">Total TVA</td>
                            <td class="text-end pe-3 fw-semibold">@TotalTva.ToString("N3") TND</td>
                        </tr>
                        <tr>
                            <td class="ps-3">Timbre fiscal</td>
                            <td class="text-end pe-3">@timbreFiscal.ToString("N3") TND</td>
                        </tr>
                        <tr class="facture-create-total-ttc-row">
                            <td class="ps-3 fw-bold">TOTAL TTC</td>
                            <td class="text-end pe-3 fw-bold fs-5">@TotalTTC.ToString("N3") TND</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* ── Action Buttons ───────────────────────────────────────────── *@
<div class="d-flex justify-content-end gap-2 mb-5 facture-create-actions">
    <a class="btn btn-outline-secondary facture-create-action-btn" href="/factures">Annuler</a>
    <button class="btn btn-primary facture-create-action-btn" @onclick="SaveFacture" disabled="@(!CanSave)">
        Enregistrer la facture
    </button>
</div>
</div>

@code {
    [Parameter] public int? Id { get; set; }

    // ── UI messages ──
    private string? summaryMessage;
    private bool summaryIsError = false;

    // ── Lookups ──
    private List<Client> clients = new();
    private List<Produit> produits = new();
    private bool lookupsLoaded;

    // ── Invoice header ──
    private string numeroFacture = string.Empty;
    private DateTime dateFacture = DateTime.Today;
    private string selectedClientId = string.Empty;

    // ── Fiscal params ──
    private decimal timbreFiscal = 1.000m;
    private StatutFacture statutFacture = StatutFacture.Brouillon;

    private bool isSaving;

    // ── Line items ──
    private List<LigneFactureVM> lignes = new();

    // ── Computed totals ──
    private decimal TotalHT => lignes.Sum(l => l.MontantHT);
    private decimal TotalTva => lignes.Sum(l => l.MontantTva);
    private decimal TotalTTC => TotalHT + TotalTva + timbreFiscal;

    private IEnumerable<TvaLine> TvaBreakdown => lignes
        .Where(l => l.TauxTva > 0)
        .GroupBy(l => l.TauxTva)
        .OrderBy(g => g.Key)
        .Select(g => new TvaLine(g.Key, g.Sum(l => l.MontantTva)));

    private bool CanSave =>
        !isSaving
        && !string.IsNullOrWhiteSpace(selectedClientId)
        && lignes.Count > 0
        && statutFacture != StatutFacture.Payee
        && statutFacture != StatutFacture.Annulee;

    protected override async Task OnParametersSetAsync()
    {
        summaryMessage = null;
        summaryIsError = false;

        if (!lookupsLoaded)
        {
            await LoadLookupsAsync();
        }

        if (Id.HasValue)
        {
            await LoadFactureAsync(Id.Value);
        }
        else
        {
            await LoadCreateDefaultsAsync();
        }
    }

    private async Task LoadLookupsAsync()
    {
        clients = await ClientService.GetAllAsync();
        produits = await ProduitService.GetAllAsync();
        lookupsLoaded = true;
    }

    private async Task LoadCreateDefaultsAsync()
    {
        numeroFacture = await FactureService.GenererNumeroAsync();
        dateFacture = DateTime.Today;
        selectedClientId = string.Empty;

        timbreFiscal = await ParametresService.GetTimbreFiscalAsync();
        statutFacture = StatutFacture.Brouillon;

        lignes = new List<LigneFactureVM>();
    }

    private async Task LoadFactureAsync(int factureId)
    {
        var facture = await FactureService.GetByIdAsync(factureId);
        if (facture is null)
        {
            NavigationManager.NavigateTo("/not-found");
            return;
        }

        numeroFacture = facture.NumeroFacture;
        dateFacture = facture.DateFacture;
        selectedClientId = facture.ClientId.ToString();
        timbreFiscal = facture.TimbreFiscal;
        statutFacture = facture.Statut;

        lignes = facture.Lignes.Select(l => new LigneFactureVM
        {
            ProduitId = l.ProduitId.ToString(),
            Designation = l.Designation,
            Quantite = l.Quantite,
            PrixUnitaireHT = l.PrixUnitaireHT,
            TauxTva = l.TauxTva
        }).ToList();
    }

    // ── Actions ──
    private void AddLine()
    {
        lignes.Add(new LigneFactureVM());
    }

    private void RemoveLine(int index)
    {
        if (index >= 0 && index < lignes.Count)
        {
            lignes.RemoveAt(index);
        }
    }

    private void OnProduitChanged(int index)
    {
        if (index < 0 || index >= lignes.Count)
        {
            return;
        }

        if (!int.TryParse(lignes[index].ProduitId, out var produitId) || produitId <= 0)
        {
            lignes[index].Designation = string.Empty;
            lignes[index].PrixUnitaireHT = 0;
            lignes[index].TauxTva = 19;
            return;
        }

        var produit = produits.FirstOrDefault(p => p.Id == produitId);
        if (produit is null)
        {
            return;
        }

        lignes[index].Designation = produit.Designation;
        lignes[index].PrixUnitaireHT = produit.PrixVenteHT;
        lignes[index].TauxTva = produit.TauxTva;
    }

    private async Task SaveFacture()
    {
        if (!int.TryParse(selectedClientId, out var clientId) || clientId <= 0)
        {
            return;
        }

        if (lignes.Count == 0)
        {
            return;
        }

        isSaving = true;
        summaryMessage = null;
        summaryIsError = false;

        try
        {
            var entityLignes = new List<LigneFacture>();

            foreach (var l in lignes)
            {
                if (!int.TryParse(l.ProduitId, out var produitId) || produitId <= 0)
                {
                    throw new ValidationException("Veuillez selectionner un produit pour toutes les lignes.");
                }

                entityLignes.Add(new LigneFacture
                {
                    ProduitId = produitId,
                    Designation = l.Designation,
                    Quantite = l.Quantite,
                    PrixUnitaireHT = l.PrixUnitaireHT,
                    TauxTva = l.TauxTva
                });
            }

            var facture = new Facture
            {
                NumeroFacture = numeroFacture.Trim(),
                DateFacture = dateFacture,
                ClientId = clientId,
                TimbreFiscal = timbreFiscal,
                Statut = statutFacture,
                Lignes = entityLignes
            };

            if (Id.HasValue)
            {
                facture.Id = Id.Value;
                await FactureService.UpdateAsync(facture);
            }
            else
            {
                facture.Statut = StatutFacture.Brouillon;
                await FactureService.CreateAsync(facture);
            }

            NavigationManager.NavigateTo("/factures");
        }
        catch (ValidationException ex)
        {
            summaryIsError = true;
            summaryMessage = ex.Message;
        }
        catch (Exception)
        {
            summaryIsError = true;
            summaryMessage = "Une erreur est survenue lors de la sauvegarde de la facture.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private string GetTvaBadgeClass(int taux) => taux switch
    {
        0 => "bg-success-subtle text-success",
        7 => "bg-info-subtle text-info",
        13 => "bg-warning-subtle text-warning-emphasis",
        19 => "bg-danger-subtle text-danger",
        _ => "bg-secondary-subtle text-secondary"
    };

    // ── View Models ──
    private class LigneFactureVM
    {
        public string ProduitId { get; set; } = string.Empty;
        public string Designation { get; set; } = string.Empty;
        public int Quantite { get; set; } = 1;
        public decimal PrixUnitaireHT { get; set; } = 0;
        public int TauxTva { get; set; } = 19;
        public decimal MontantHT => Quantite * PrixUnitaireHT;
        public decimal MontantTva => MontantHT * TauxTva / 100m;
    }

    private record TvaLine(int Taux, decimal Montant);
}
