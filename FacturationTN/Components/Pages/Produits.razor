    private async Task LoadPageDataAsync()
    {
        categoriesProduitDb = await ProduitService.GetCategoriesAsync();
        categoriesProduit = categoriesProduitDb.Select(c => c.Nom).ToList();

        unitesMesureDb = await ProduitService.GetUnitesAsync();
        unitesMesure = unitesMesureDb.Select(u => u.Nom).ToList();

        allProduits = await ProduitService.GetAllAsync();
        ApplyFilters();
        TryOpenEditFromQuery();
    }

    private void TryOpenEditFromQuery()
    {
        if (!EditId.HasValue || EditId == lastHandledEditId || allProduits.Count == 0)
        {
            return;
        }

        var requestedProduit = allProduits.FirstOrDefault(p => p.Id == EditId.Value);
        lastHandledEditId = EditId;

        if (requestedProduit is null)
        {
            summaryIsError = true;
            summaryMessage = "Le produit a modifier est introuvable.";
            return;
        }

        ShowEditForm(requestedProduit);
        NavigationManager.NavigateTo("/produits", replace: true);
    }

    private void OnFormCategorieProduitChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        if (val == "__new__")
        {
            showNewCategorieProduit = true;
            newCategorieProduit = string.Empty;
        }
        else
        {
            formCategorie = val;
        }
    }

    private async Task AddCategorieProduit()
    {
        var trimmed = newCategorieProduit.Trim();
        if (string.IsNullOrWhiteSpace(trimmed) || isCreatingCategory)
        {
            return;
        }

        isCreatingCategory = true;
        try
        {
            var existing = categoriesProduitDb
                .FirstOrDefault(c => string.Equals(c.Nom, trimmed, StringComparison.OrdinalIgnoreCase));

            if (existing is null)
            {
                var created = await ProduitService.CreateCategorieAsync(trimmed);
                categoriesProduitDb.Add(created);
            }

            categoriesProduit = categoriesProduitDb
                .Select(c => c.Nom)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(n => n)
                .ToList();

            formCategorie = categoriesProduit
                .First(c => string.Equals(c, trimmed, StringComparison.OrdinalIgnoreCase));

            showNewCategorieProduit = false;
            newCategorieProduit = string.Empty;
            summaryMessage = string.Empty;
            summaryIsError = false;
        }
        catch (ValidationException ex)
        {
            summaryIsError = true;
            summaryMessage = ex.Message;
        }
        catch
        {
            summaryIsError = true;
            summaryMessage = "Impossible de créer la catégorie pour le moment.";
        }
        finally
        {
            isCreatingCategory = false;
        }
    }

    private void CancelNewCategorieProduit()
    {
        showNewCategorieProduit = false;
        newCategorieProduit = string.Empty;
