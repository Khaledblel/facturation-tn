    private async Task ConfirmDeleteProduitAsync()
    {
        if (isDeleting || produitToDeleteId is null)
        {
            return;
        }

        isDeleting = true;
        summaryMessage = string.Empty;
        summaryIsError = false;

        try
        {
            await ProduitService.DeleteAsync(produitToDeleteId.Value);
            await LoadPageDataAsync();

            summaryIsError = false;
            summaryMessage = "Produit supprimé avec succès.";
            HideDeleteConfirmation();
        }
        catch (InvalidOperationException ex)
        {
            summaryIsError = true;
            summaryMessage = ex.Message;
        }
        catch
        {
            summaryIsError = true;
            summaryMessage = "Une erreur est survenue lors de la suppression du produit.";
        }
        finally
        {
            isDeleting = false;
        }
    }

    private void ApplyFilters()
    {
        IEnumerable<Produit> query = allProduits;

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim();
            query = query.Where(p =>
                p.Reference.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                p.Designation.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(p.Marque) && p.Marque.Contains(term, StringComparison.OrdinalIgnoreCase)));
        }

        if (!string.IsNullOrWhiteSpace(filterType))
        {
            var type = filterType == "Service" ? TypeProduit.Service : TypeProduit.Produit;
            query = query.Where(p => p.TypeProduit == type);
        }

        if (!string.IsNullOrWhiteSpace(filterCategorie))
        {
            query = query.Where(p => string.Equals(p.Categorie?.Nom, filterCategorie, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(filterStatut) && TryParseStatut(filterStatut, out var statut))
        {
            query = query.Where(p => p.Statut == statut);
        }

        if (filterTva >= 0)
        {
            query = query.Where(p => p.TauxTva == filterTva);
        }

        filteredProduits = query
            .OrderByDescending(p => p.DateCreation)
            .ToList();

        filteredCount = filteredProduits.Count;
        currentStart = filteredCount == 0 ? 0 : 1;
        currentEnd = filteredCount;
    }

    private void ResetForm()
    {
        formTypeProduit = string.Empty;
        formCategorie = string.Empty;
        formStatut = "Actif";
        formReference = string.Empty;
        formDesignation = string.Empty;
        formMarque = string.Empty;
        formUnite = string.Empty;
        formPrixAchatHT = 0;
        formPrixHT = 0;
        formTauxTva = 19;
        formRemiseMax = 0;
        formSuiviStock = false;
        formQuantiteStock = 0;
        formSeuilAlerte = 0;
        formDescription = string.Empty;
        formNotes = string.Empty;
        showNewCategorieProduit = false;
        newCategorieProduit = string.Empty;
        showNewUnite = false;
        newUnite = string.Empty;
    }

    private async Task SaveProduitAsync()
    {
        if (isSaving)
        {
            return;
        }

        summaryMessage = string.Empty;
        summaryIsError = false;

        var produit = BuildProduitFromForm();
        produit.CategorieProduitId = await ResolveSelectedCategoryIdAsync(formCategorie);
        produit.UniteMesureId = await ResolveSelectedUniteIdAsync(formUnite);

        var validationResults = new List<ValidationResult>();
        var validationContext = new ValidationContext(produit);

        if (!Validator.TryValidateObject(produit, validationContext, validationResults, validateAllProperties: true))
        {
            summaryIsError = true;
            summaryMessage = validationResults[0].ErrorMessage ?? "Veuillez verifier les informations du formulaire.";
            return;
        }

        isSaving = true;
        try
        {
            if (isEditing && editingProduitId.HasValue)
            {
                produit.Id = editingProduitId.Value;
                await ProduitService.UpdateAsync(produit);
                summaryMessage = "Produit mis a jour avec succes.";
            }
            else
            {
                await ProduitService.CreateAsync(produit);
                summaryMessage = "Produit créé avec succès.";
            }

            await LoadPageDataAsync();

            summaryIsError = false;
            HideForm();
            ResetForm();
        }
        catch (ValidationException ex)
        {
            summaryIsError = true;
            summaryMessage = ex.Message;
        }
        catch
        {
            summaryIsError = true;
            summaryMessage = isEditing
                ? "Une erreur est survenue lors de la mise a jour du produit."
                : "Une erreur est survenue lors de la création du produit.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private Produit BuildProduitFromForm()
    {
        var typeProduit = formTypeProduit switch
        {
            "Produit" => TypeProduit.Produit,
            "Service" => TypeProduit.Service,
            _ => TypeProduit.NonDefini
        };

        var statut = TryParseStatut(formStatut, out var parsedStatut)
            ? parsedStatut
            : StatutProduit.Actif;

        var isService = typeProduit == TypeProduit.Service;

        return new Produit
        {
            TypeProduit = typeProduit,
            Statut = statut,
            CategorieProduitId = null,
            Reference = (formReference ?? string.Empty).Trim(),
            Designation = (formDesignation ?? string.Empty).Trim(),
            Marque = isService ? null : NullIfWhiteSpace(formMarque),
            UniteMesureId = null,
            PrixAchatHT = formPrixAchatHT,
            PrixVenteHT = formPrixHT,
            TauxTva = formTauxTva,
            RemiseMax = formRemiseMax,
            SuiviStock = isService ? false : formSuiviStock,
            QuantiteStock = isService || !formSuiviStock ? 0 : formQuantiteStock,
            SeuilAlerte = isService || !formSuiviStock ? 0 : formSeuilAlerte,
            Description = NullIfWhiteSpace(formDescription),
            Notes = NullIfWhiteSpace(formNotes)
        };
    }

    private async Task<int?> ResolveSelectedCategoryIdAsync(string? selectedCategoryName)
    {
        if (string.IsNullOrWhiteSpace(selectedCategoryName))
        {
            return null;
        }

        var existing = categoriesProduitDb
            .FirstOrDefault(c => string.Equals(c.Nom, selectedCategoryName, StringComparison.OrdinalIgnoreCase));

        if (existing is not null)
        {
            return existing.Id;
        }

        var created = await ProduitService.CreateCategorieAsync(selectedCategoryName);
        categoriesProduitDb.Add(created);
        categoriesProduit = categoriesProduitDb.Select(c => c.Nom).OrderBy(n => n).ToList();
        return created.Id;
    }

    private async Task<int?> ResolveSelectedUniteIdAsync(string? selectedUniteName)
    {
        if (string.IsNullOrWhiteSpace(selectedUniteName))
        {
            return null;
        }

        var existing = unitesMesureDb
            .FirstOrDefault(u => string.Equals(u.Nom, selectedUniteName, StringComparison.OrdinalIgnoreCase));

        if (existing is not null)
        {
            return existing.Id;
        }

        var created = await ProduitService.CreateUniteAsync(selectedUniteName);
        unitesMesureDb.Add(created);
        unitesMesure = unitesMesureDb.Select(u => u.Nom).OrderBy(n => n).ToList();
        return created.Id;
    }

    private static string? NullIfWhiteSpace(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private static bool TryParseStatut(string value, out StatutProduit statut)
    {
        var normalized = value.Trim() switch
        {
            "Discontinué" => "Discontinue",
            _ => value.Trim()
        };

        return Enum.TryParse(normalized, true, out statut);
    }

    private static string GetStatutLabel(StatutProduit statut)
    {
        return statut switch
        {
            StatutProduit.Discontinue => "Discontinué",
            _ => statut.ToString()
        };
    }

    private static string GetTypeLabel(TypeProduit typeProduit)
    {
        return typeProduit switch
        {
            TypeProduit.Produit => "Produit",
            TypeProduit.Service => "Service",
            _ => "-"
        };
    }

    private static string GetStatusBadgeClass(StatutProduit statut)
    {
        return statut switch
        {
            StatutProduit.Actif => "bg-success-subtle text-success-emphasis",
            StatutProduit.Inactif => "bg-secondary-subtle text-secondary-emphasis",
            StatutProduit.Discontinue => "bg-warning-subtle text-warning-emphasis",
            _ => "bg-light text-dark"
        };
    }
}
