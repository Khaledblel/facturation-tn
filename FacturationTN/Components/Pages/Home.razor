@page "/"
@rendermode InteractiveServer

<PageTitle>Tableau de bord</PageTitle>

<h1 class="mb-4">Tableau de bord</h1>

@* ═══════════════════════════════════════════════════════════════ *@
@* TOP KPI SUMMARY CARDS                                          *@
@* ═══════════════════════════════════════════════════════════════ *@
<div class="row g-3 mb-4">
    <div class="col-xl col-md-4 col-sm-6">
        <div class="card kpi-card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold">Chiffre d'affaires TTC</div>
                <div class="fs-4 fw-bold text-primary mt-1">0.000 <span class="fs-6 fw-normal">TND</span></div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6">
        <div class="card kpi-card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold">Chiffre d'affaires HT</div>
                <div class="fs-4 fw-bold text-success mt-1">0.000 <span class="fs-6 fw-normal">TND</span></div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6">
        <div class="card kpi-card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold">TVA totale collectée</div>
                <div class="fs-4 fw-bold text-warning mt-1">0.000 <span class="fs-6 fw-normal">TND</span></div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6">
        <div class="card kpi-card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold">Timbre fiscal total</div>
                <div class="fs-4 fw-bold text-danger mt-1">0.000 <span class="fs-6 fw-normal">TND</span></div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6">
        <div class="card kpi-card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold">Nombre de factures</div>
                <div class="fs-4 fw-bold text-info mt-1">0</div>
            </div>
        </div>
    </div>
</div>

@* ═══════════════════════════════════════════════════════════════ *@
@* TABLEAU DE BORD FISCAL                                         *@
@* ═══════════════════════════════════════════════════════════════ *@
<h4 class="mb-3">Tableau de bord fiscal</h4>
<div class="row g-3 mb-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">TVA par taux</div>
            <div class="card-body">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Taux TVA</th>
                            <th class="text-end">Base HT</th>
                            <th class="text-end">Montant TVA</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>0 %</td>
                            <td class="text-end">0.000 TND</td>
                            <td class="text-end">0.000 TND</td>
                        </tr>
                        <tr>
                            <td>7 %</td>
                            <td class="text-end">0.000 TND</td>
                            <td class="text-end">0.000 TND</td>
                        </tr>
                        <tr>
                            <td>13 %</td>
                            <td class="text-end">0.000 TND</td>
                            <td class="text-end">0.000 TND</td>
                        </tr>
                        <tr>
                            <td>19 %</td>
                            <td class="text-end">0.000 TND</td>
                            <td class="text-end">0.000 TND</td>
                        </tr>
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td>Total</td>
                            <td class="text-end">0.000 TND</td>
                            <td class="text-end">0.000 TND</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Détail timbre fiscal</div>
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="chart-placeholder d-flex align-items-center justify-content-center">
                    <span class="text-muted">Graphique TVA par taux — à venir</span>
                </div>
                <hr />
                <div class="row text-center">
                    <div class="col">
                        <div class="text-muted small">Montant unitaire</div>
                        <div class="fw-bold">1.000 TND</div>
                    </div>
                    <div class="col">
                        <div class="text-muted small">Factures concernées</div>
                        <div class="fw-bold">0</div>
                    </div>
                    <div class="col">
                        <div class="text-muted small">Total timbre</div>
                        <div class="fw-bold">0.000 TND</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ═══════════════════════════════════════════════════════════════ *@
@* TABLEAU DE BORD VENTES                                         *@
@* ═══════════════════════════════════════════════════════════════ *@
<h4 class="mb-3">Tableau de bord ventes</h4>

@* CA par période *@
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                Chiffre d'affaires par période
                <div>
                    <button class="btn btn-sm @(selectedPeriodView == "HT" ? "btn-primary" : "btn-outline-primary")" @onclick='() => selectedPeriodView = "HT"'>HT</button>
                    <button class="btn btn-sm @(selectedPeriodView == "TTC" ? "btn-primary" : "btn-outline-primary")" @onclick='() => selectedPeriodView = "TTC"'>TTC</button>
                </div>
            </div>
            <div class="card-body">
                <div class="chart-placeholder chart-placeholder-lg d-flex align-items-center justify-content-center">
                    <span class="text-muted">Graphique CA @selectedPeriodView par mois — à venir</span>
                </div>
            </div>
        </div>
    </div>
</div>

@* CA par client & CA par produit *@
<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Chiffre d'affaires par client</div>
            <div class="card-body">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Client</th>
                            <th class="text-end">CA HT</th>
                            <th class="text-end">CA TTC</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">Aucune donnée disponible</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Chiffre d'affaires par produit</div>
            <div class="card-body">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Produit</th>
                            <th class="text-end">CA HT</th>
                            <th class="text-end">CA TTC</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">Aucune donnée disponible</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private string selectedPeriodView = "TTC";
}
