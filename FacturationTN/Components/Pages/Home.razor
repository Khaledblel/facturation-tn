@page "/"
@rendermode InteractiveServer

@using FacturationTN.Services.Interfaces
@using FacturationTN.Models
@using FacturationTN.Models.Enums
@inject IFactureService FactureService

<PageTitle>Tableau de bord</PageTitle>

<div class="dashboard-top mb-4">
<section class="dashboard-hero mb-4">
    <div class="dashboard-hero-inner">
        <div>
            <p class="dashboard-eyebrow mb-2">Vue d'ensemble</p>
            <h1 class="mb-2 dashboard-title">Tableau de bord</h1>
            <p class="mb-0 dashboard-subtitle">Suivez instantanément la performance commerciale et la santé de la facturation.</p>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════ *@
@* TOP KPI SUMMARY CARDS                                          *@
@* ═══════════════════════════════════════════════════════════════ *@
<div class="row g-3 mb-4 dashboard-kpi-grid">
    <div class="col-xl col-md-4 col-sm-6">
        <div class="card border-0 shadow-sm h-100 dashboard-kpi-card dashboard-kpi-primary">
            <div class="card-body">
                <div class="dashboard-kpi-label">Chiffre d'affaires TTC</div>
                <div class="dashboard-kpi-value mt-1">@totalTtc.ToString("N3") <span class="dashboard-kpi-unit">TND</span></div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6">
        <div class="card border-0 shadow-sm h-100 dashboard-kpi-card dashboard-kpi-success">
            <div class="card-body">
                <div class="dashboard-kpi-label">Chiffre d'affaires HT</div>
                <div class="dashboard-kpi-value mt-1">@totalHt.ToString("N3") <span class="dashboard-kpi-unit">TND</span></div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6">
        <div class="card border-0 shadow-sm h-100 dashboard-kpi-card dashboard-kpi-warning">
            <div class="card-body">
                <div class="dashboard-kpi-label">TVA totale collectée</div>
                <div class="dashboard-kpi-value mt-1">@totalTva.ToString("N3") <span class="dashboard-kpi-unit">TND</span></div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6">
        <div class="card border-0 shadow-sm h-100 dashboard-kpi-card dashboard-kpi-danger">
            <div class="card-body">
                <div class="dashboard-kpi-label">Timbre fiscal total</div>
                <div class="dashboard-kpi-value mt-1">@totalTimbre.ToString("N3") <span class="dashboard-kpi-unit">TND</span></div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6">
        <div class="card border-0 shadow-sm h-100 dashboard-kpi-card dashboard-kpi-info">
            <div class="card-body">
                <div class="dashboard-kpi-label">Nombre de factures</div>
                <div class="dashboard-kpi-value mt-1">@totalFactures</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4 dashboard-kpi-grid">
    <div class="col-xl col-md-4 col-sm-6">
        <div class="card border-0 shadow-sm h-100 dashboard-kpi-card dashboard-kpi-primary">
            <div class="card-body">
                <div class="dashboard-kpi-label">Factures validées</div>
                <div class="dashboard-kpi-value mt-1">@validatedFactures <span class="dashboard-kpi-unit">factures</span></div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6">
        <div class="card border-0 shadow-sm h-100 dashboard-kpi-card dashboard-kpi-success">
            <div class="card-body">
                <div class="dashboard-kpi-label">Factures payées</div>
                <div class="dashboard-kpi-value mt-1">@paidFactures <span class="dashboard-kpi-unit">factures</span></div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6">
        <div class="card border-0 shadow-sm h-100 dashboard-kpi-card dashboard-kpi-warning">
            <div class="card-body">
                <div class="dashboard-kpi-label">Clients actifs</div>
                <div class="dashboard-kpi-value mt-1">@activeClients <span class="dashboard-kpi-unit">clients</span></div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-4 col-sm-6">
        <div class="card border-0 shadow-sm h-100 dashboard-kpi-card dashboard-kpi-danger">
            <div class="card-body">
                <div class="dashboard-kpi-label">Produits vendus</div>
                <div class="dashboard-kpi-value mt-1">@soldProducts <span class="dashboard-kpi-unit">produits</span></div>
            </div>
        </div>
    </div>
</div>
</div>

@* ═══════════════════════════════════════════════════════════════ *@
@* RAPIDE : MOIS EN COURS                                        *@
@* ═══════════════════════════════════════════════════════════════ *@
<div class="dashboard-middle">
<div class="row g-3 mb-4">
    <div class="col-lg-3 col-md-6">
        <div class="card border-0 shadow-sm h-100 dashboard-mid-card dashboard-month-card">
            <div class="card-header bg-white fw-semibold dashboard-mid-header">@currentMonthLabel</div>
            <div class="card-body text-center">
                <div class="dashboard-stat-label">Factures ce mois</div>
                <div class="dashboard-month-count mt-1">@monthFactures</div>
                <div class="dashboard-stat-label mt-3">CA HT</div>
                <div class="dashboard-month-value dashboard-month-value-ht">@monthHt.ToString("N3") TND</div>
                <div class="dashboard-stat-label mt-2">CA TTC</div>
                <div class="dashboard-month-value dashboard-month-value-ttc">@monthTtc.ToString("N3") TND</div>
            </div>
        </div>
    </div>
    <div class="col-lg-9 col-md-6">
        <div class="card border-0 shadow-sm h-100 dashboard-mid-card dashboard-status-card">
            <div class="card-header bg-white fw-semibold dashboard-mid-header">Synthèse des statuts</div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-sm-4 mb-2">
                        <div class="dashboard-stat-label">Validées</div>
                        <div class="dashboard-stat-value dashboard-stat-value-primary">@validatedFactures</div>
                    </div>
                    <div class="col-sm-4 mb-2">
                        <div class="dashboard-stat-label">Payées</div>
                        <div class="dashboard-stat-value dashboard-stat-value-success">@paidFactures</div>
                    </div>
                    <div class="col-sm-4 mb-2">
                        <div class="dashboard-stat-label">Clients actifs</div>
                        <div class="dashboard-stat-value dashboard-stat-value-warning">@activeClients</div>
                    </div>
                </div>
                <div class="progress mt-3 dashboard-paid-progress" style="height:10px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width:@(totalFactures == 0 ? 0 : (int)Math.Min(100, (decimal)paidFactures * 100 / totalFactures))%" aria-valuenow="@(totalFactures == 0 ? 0 : (int)Math.Min(100, (decimal)paidFactures * 100 / totalFactures))" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <div class="text-end small text-muted mt-1 dashboard-progress-label">% de factures payées</div>
            </div>
        </div>
    </div>
</div>

@* ═══════════════════════════════════════════════════════════════ *@
@* TABLEAU DE BORD FISCAL                                         *@
@* ═══════════════════════════════════════════════════════════════ *@
<h4 class="mb-3 dashboard-section-title">Tableau de bord fiscal</h4>
<div class="row g-3 mb-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100 dashboard-mid-card">
            <div class="card-header bg-white fw-semibold dashboard-mid-header">TVA par taux</div>
            <div class="card-body">
                <table class="table table-sm table-hover mb-0 dashboard-table">
                    <thead>
                        <tr>
                            <th>Taux TVA</th>
                            <th class="text-end">Base HT</th>
                            <th class="text-end">Montant TVA</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in tvaByRate)
                        {
                            <tr>
                                <td>@row.Taux %</td>
                                <td class="text-end">@row.BaseHt.ToString("N3") TND</td>
                                <td class="text-end">@row.MontantTva.ToString("N3") TND</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="fw-bold dashboard-table-foot">
                        <tr>
                            <td>Total</td>
                            <td class="text-end">@totalBaseHt.ToString("N3") TND</td>
                            <td class="text-end">@totalTva.ToString("N3") TND</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100 dashboard-mid-card">
            <div class="card-header bg-white fw-semibold dashboard-mid-header">Détail timbre fiscal</div>
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="chart-placeholder dashboard-chart-box d-flex align-items-center justify-content-center">
                    <div style="width:100%; padding:12px;">
                        @foreach (var row in tvaByRate)
                        {
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div style="width:52px;">@row.Taux %</div>
                                <div class="flex-grow-1" style="height:10px; background:#e9ecef; border-radius:6px;">
                                    <div style="height:100%; width:@GetBarWidth(row.MontantTva)%; background:#f59e0b; border-radius:6px;"></div>
                                </div>
                                <div style="width:110px; text-align:right;">
                                    @row.MontantTva.ToString("N3")
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <hr />
                <div class="row text-center">
                    <div class="col">
                        <div class="dashboard-stat-label">Montant unitaire</div>
                        <div class="fw-bold dashboard-stat-inline">@timbreUnitaire.ToString("N3") TND</div>
                    </div>
                    <div class="col">
                        <div class="dashboard-stat-label">Factures concernées</div>
                        <div class="fw-bold dashboard-stat-inline">@nbFacturesTimbre</div>
                    </div>
                    <div class="col">
                        <div class="dashboard-stat-label">Total timbre</div>
                        <div class="fw-bold dashboard-stat-inline">@totalTimbre.ToString("N3") TND</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

@* ═══════════════════════════════════════════════════════════════ *@
@* TABLEAU DE BORD VENTES                                         *@
@* ═══════════════════════════════════════════════════════════════ *@
<div class="dashboard-sales">
<h4 class="mb-3 dashboard-section-title">Tableau de bord ventes</h4>

@* CA par période *@
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm dashboard-sales-card">
            <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center dashboard-sales-header">
                Chiffre d'affaires par période
                <div class="dashboard-sales-toggle">
                    <button class="btn btn-sm dashboard-sales-toggle-btn @(selectedPeriodView == "HT" ? "btn-primary" : "btn-outline-primary")" @onclick='() => selectedPeriodView = "HT"'>HT</button>
                    <button class="btn btn-sm dashboard-sales-toggle-btn @(selectedPeriodView == "TTC" ? "btn-primary" : "btn-outline-primary")" @onclick='() => selectedPeriodView = "TTC"'>TTC</button>
                </div>
            </div>
            <div class="card-body">
                <div class="chart-placeholder chart-placeholder-lg dashboard-sales-chart d-flex align-items-center justify-content-center">
                    <div style="width:100%; padding:12px;">
                        @if (caByMonth.Count == 0)
                        {
                            <span class="text-muted">Aucune donnée de ventes.</span>
                        }
                        else
                        {
                            @foreach (var m in caByMonth)
                            {
                                var value = selectedPeriodView == "HT" ? m.CaHt : m.CaTtc;
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <div style="width:90px;">@m.Mois</div>
                                    <div class="flex-grow-1" style="height:10px; background:#e9ecef; border-radius:6px;">
                                        <div style="height:100%; width:@GetMonthlyBarWidth(value)%; background:#2563eb; border-radius:6px;"></div>
                                    </div>
                                    <div style="width:110px; text-align:right;">
                                        @value.ToString("N3")
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* CA par client & CA par produit *@
<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100 dashboard-sales-card">
            <div class="card-header bg-white fw-semibold dashboard-sales-header">Chiffre d'affaires par client</div>
            <div class="card-body">
                <table class="table table-sm table-hover mb-0 dashboard-sales-table">
                    <thead>
                        <tr>
                            <th>Client</th>
                            <th class="text-end">CA HT</th>
                            <th class="text-end">CA TTC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (caByClient.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">Aucune donnée disponible</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var row in caByClient)
                            {
                                <tr>
                                    <td>@row.ClientName</td>
                                    <td class="text-end">@row.CaHt.ToString("N3") TND</td>
                                    <td class="text-end">@row.CaTtc.ToString("N3") TND</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100 dashboard-sales-card">
            <div class="card-header bg-white fw-semibold dashboard-sales-header">Chiffre d'affaires par produit</div>
            <div class="card-body">
                <table class="table table-sm table-hover mb-0 dashboard-sales-table">
                    <thead>
                        <tr>
                            <th>Produit</th>
                            <th class="text-end">CA HT</th>
                            <th class="text-end">CA TTC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (caByProduit.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">Aucune donnée disponible</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var row in caByProduit)
                            {
                                <tr>
                                    <td>@row.ProduitLabel</td>
                                    <td class="text-end">@row.CaHt.ToString("N3") TND</td>
                                    <td class="text-end">@row.CaTtc.ToString("N3") TND</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
</div>

@code {
    private string selectedPeriodView = "TTC";

    // ── KPI Summary ──
    private decimal totalTtc;
    private decimal totalHt;
    private decimal totalTva;
    private decimal totalTimbre;
    private int totalFactures;

    // ── Fiscal ──
    private List<TvaRow> tvaByRate = new();
    private decimal totalBaseHt;
    private decimal timbreUnitaire;
    private int nbFacturesTimbre;
    private decimal tvaMaxMontant;

    // ── Sales ──
    private List<MonthlyCA> caByMonth = new();
    private decimal maxCaHt;
    private decimal maxCaTtc;

    private List<ClientCA> caByClient = new();
    private List<ProduitCA> caByProduit = new();

    // ── Facture status & extra KPIs ──
    private int validatedFactures;
    private int paidFactures;
    private int activeClients;
    private int soldProducts;
    private int monthFactures;
    private decimal monthHt;
    private decimal monthTtc;
    private string currentMonthLabel = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAndComputeAsync();
    }

    private async Task LoadAndComputeAsync()
    {
        var allFactures = await LoadAllFacturesAsync() ?? new List<Facture>();

        // On analyse uniquement les factures "commerciales" (validées/paiées).
        var salesFactures = allFactures
            .Where(f => f.Statut == StatutFacture.Validee || f.Statut == StatutFacture.Payee)
            .ToList();

        totalFactures = salesFactures.Count;
        totalHt = salesFactures.Sum(f => f.TotalHT);
        totalTva = salesFactures.Sum(f => f.TotalTVA);
        totalTimbre = salesFactures.Sum(f => f.TimbreFiscal);
        totalTtc = salesFactures.Sum(f => f.TotalTTC);

        validatedFactures = salesFactures.Count(f => f.Statut == StatutFacture.Validee);
        paidFactures = salesFactures.Count(f => f.Statut == StatutFacture.Payee);
        activeClients = salesFactures.Select(f => f.ClientId).Distinct().Count();

        var allLines = salesFactures.SelectMany(f => f.Lignes).ToList();
        soldProducts = allLines.Select(l => l.ProduitId).Distinct().Count();

        var now = DateTime.Now;
        currentMonthLabel = now.ToString("MMMM yyyy");
        var monthInvoices = salesFactures.Where(f => f.DateFacture.Year == now.Year && f.DateFacture.Month == now.Month).ToList();
        monthFactures = monthInvoices.Count;
        monthHt = monthInvoices.Sum(f => f.TotalHT);
        monthTtc = monthInvoices.Sum(f => f.TotalTTC);

        // TVA par taux (tableau fixe 0/7/13/19)
        var tvaRates = new[] { 0, 7, 13, 19 };

        tvaByRate = tvaRates
            .Select(rate =>
            {
                var baseHt = allLines.Where(l => l.TauxTva == rate).Sum(l => l.MontantHT);
                var montantTva = allLines.Where(l => l.TauxTva == rate).Sum(l => l.MontantTva);
                return new TvaRow(rate, baseHt, montantTva);
            })
            .ToList();

        totalBaseHt = tvaByRate.Sum(r => r.BaseHt);
        tvaMaxMontant = tvaByRate.Max(r => r.MontantTva);

        timbreUnitaire = salesFactures
            .Select(f => f.TimbreFiscal)
            .Where(x => x > 0)
            .Distinct()
            .OrderBy(x => x)
            .FirstOrDefault();
        nbFacturesTimbre = salesFactures.Count(f => f.TimbreFiscal > 0);

        // CA par mois (HT et TTC)
        caByMonth = salesFactures
            .GroupBy(f => new { f.DateFacture.Year, f.DateFacture.Month })
            .Select(g => new MonthlyCA(
                $"{g.Key.Year}-{g.Key.Month:00}",
                g.Sum(x => x.TotalHT),
                g.Sum(x => x.TotalTTC)))
            .OrderBy(x => x.Mois)
            .ToList();

        maxCaHt = caByMonth.Count == 0 ? 0 : caByMonth.Max(x => x.CaHt);
        maxCaTtc = caByMonth.Count == 0 ? 0 : caByMonth.Max(x => x.CaTtc);

        // CA par client (HT et TTC au niveau facture)
        caByClient = salesFactures
            .GroupBy(f => new { f.ClientId, Name = f.Client != null ? f.Client.Nom : string.Empty })
            .Select(g => new ClientCA(
                g.Key.Name,
                g.Sum(x => x.TotalHT),
                g.Sum(x => x.TotalTTC)))
            .OrderByDescending(x => x.CaTtc)
            .ToList();

        // CA par produit (HT/TVA/TTC au niveau lignes; le timbre est ventilé au niveau facture)
        caByProduit = allLines
            .GroupBy(l => new { l.ProduitId, Label = l.Designation })
            .Select(g => new ProduitCA(
                g.Key.Label,
                g.Sum(x => x.MontantHT),
                g.Sum(x => x.MontantTTC)))
            .OrderByDescending(x => x.CaTtc)
            .ToList();
    }

    private async Task<List<Facture>> LoadAllFacturesAsync()
    {
        var result = new List<Facture>();
        var page = 1;
        const int pageSize = 2000;

        while (true)
        {
            var (items, totalCount) = await FactureService.SearchAsync(
                searchTerm: null,
                dateFrom: null,
                dateTo: null,
                clientId: null,
                page: page,
                pageSize: pageSize);

            result.AddRange(items);

            if (result.Count >= totalCount || items.Count == 0)
            {
                break;
            }

            page++;
        }

        return result;
    }

    private string GetBarWidth(decimal value)
    {
        if (tvaMaxMontant <= 0)
        {
            return "0";
        }

        var percent = (value / tvaMaxMontant) * 100m;
        return percent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    }

    private string GetMonthlyBarWidth(decimal value)
    {
        var max = selectedPeriodView == "HT" ? maxCaHt : maxCaTtc;
        if (max <= 0)
        {
            return "0";
        }

        var percent = (value / max) * 100m;
        return percent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    }

    private record TvaRow(int Taux, decimal BaseHt, decimal MontantTva);
    private record MonthlyCA(string Mois, decimal CaHt, decimal CaTtc);
    private record ClientCA(string ClientName, decimal CaHt, decimal CaTtc);
    private record ProduitCA(string ProduitLabel, decimal CaHt, decimal CaTtc);
}
