    }

    private int GetCategorieClientUsageCount(int categorieClientId)
    {
        return allClients.Count(c => c.CategorieClientId == categorieClientId);
    }

    private async Task AddCategorieClient()
    {
        var trimmed = newCategorieClient.Trim();
        if (string.IsNullOrWhiteSpace(trimmed) || isCreatingCategory)
        {
            return;
        }

        isCreatingCategory = true;
        try
        {
            var existing = categoriesClientDb
                .FirstOrDefault(c => string.Equals(c.Nom, trimmed, StringComparison.OrdinalIgnoreCase));

            if (existing is null)
            {
                var created = await ClientService.CreateCategorieAsync(trimmed);
                categoriesClientDb.Add(created);
            }

            categoriesClient = categoriesClientDb
                .Select(c => c.Nom)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(n => n)
                .ToList();

            formCategorie = categoriesClient
                .First(c => string.Equals(c, trimmed, StringComparison.OrdinalIgnoreCase));

            summaryMessage = string.Empty;
            summaryIsError = false;
            showNewCategorieClient = false;
            newCategorieClient = string.Empty;
        }
        catch (ValidationException ex)
        {
            summaryIsError = true;
            summaryMessage = ex.Message;
        }
        catch
        {
            summaryIsError = true;
            summaryMessage = "Impossible de créer la categorie pour le moment.";
        }
        finally
        {
            isCreatingCategory = false;
        }
    }

    private void CancelNewCategorieClient()
    {
