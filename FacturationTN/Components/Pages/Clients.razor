    private async Task LoadPageDataAsync()
    {
        categoriesClientDb = await ClientService.GetCategoriesAsync();
        categoriesClient = categoriesClientDb.Select(c => c.Nom).ToList();

        allClients = await ClientService.GetAllAsync();
        ApplyFilters();
        TryOpenEditFromQuery();
    }

    private void TryOpenEditFromQuery()
    {
        if (!EditId.HasValue || EditId == lastHandledEditId || allClients.Count == 0)
        {
            return;
        }

        var requestedClient = allClients.FirstOrDefault(c => c.Id == EditId.Value);
        lastHandledEditId = EditId;

        if (requestedClient is null)
        {
            summaryIsError = true;
            summaryMessage = "Le client a modifier est introuvable.";
            return;
        }

        ShowEditForm(requestedClient);
        NavigationManager.NavigateTo("/clients", replace: true);
    }

    private void OnFormCategorieClientChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        if (val == "__new__")
        {
            showNewCategorieClient = true;
            newCategorieClient = string.Empty;
        }
        else if (val == "__delete__")
        {
            showNewCategorieClient = false;
            newCategorieClient = string.Empty;
            ShowDeleteCategorieClientModal();
        }
        else
        {
            formCategorie = val;
        }
    }

    private void ShowDeleteCategorieClientModal()
