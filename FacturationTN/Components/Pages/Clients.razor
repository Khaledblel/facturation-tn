        isDeleting = true;
        summaryMessage = string.Empty;
        summaryIsError = false;

        try
        {
            await ClientService.DeleteAsync(clientToDeleteId.Value);
            await LoadPageDataAsync();

            summaryIsError = false;
            summaryMessage = "Client supprimé avec succès.";
            HideDeleteConfirmation();
        }
        catch (InvalidOperationException ex)
        {
            summaryIsError = true;
            summaryMessage = ex.Message;
        }
        catch
        {
            summaryIsError = true;
            summaryMessage = "Une erreur est survenue lors de la suppression du client.";
        }
        finally
        {
            isDeleting = false;
        }
    }

    private void ApplyFilters()
    {
        IEnumerable<Client> query = allClients;

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim();
            query = query.Where(c =>
                c.Nom.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                c.MatriculeFiscale.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(c.Email) && c.Email.Contains(term, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrWhiteSpace(c.Telephone) && c.Telephone.Contains(term, StringComparison.OrdinalIgnoreCase)));
        }

        if (!string.IsNullOrWhiteSpace(filterCategorie))
        {
            query = query.Where(c => string.Equals(c.Categorie?.Nom, filterCategorie, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(filterStatut) && Enum.TryParse<StatutClient>(filterStatut, true, out var statut))
        {
            query = query.Where(c => c.Statut == statut);
        }

        if (!string.IsNullOrWhiteSpace(filterGouvernorat))
        {
            query = query.Where(c => string.Equals(c.Gouvernorat, filterGouvernorat, StringComparison.OrdinalIgnoreCase));
        }

        filteredClients = query
            .OrderByDescending(c => c.DateCreation)
            .ToList();

        filteredCount = filteredClients.Count;
        currentStart = filteredCount == 0 ? 0 : 1;
        currentEnd = filteredCount;
    }

    private async Task SaveClient()
    {
        if (isSaving)
        {
            return;
        }

        summaryMessage = string.Empty;
        summaryIsError = false;

        var client = BuildClientFromForm();
        client.CategorieClientId = await ResolveSelectedCategoryIdAsync(formCategorie);
        var validationResults = new List<ValidationResult>();
        var validationContext = new ValidationContext(client);

        if (!Validator.TryValidateObject(client, validationContext, validationResults, validateAllProperties: true))
        {
            summaryIsError = true;
            summaryMessage = validationResults[0].ErrorMessage ?? "Veuillez verifier les informations du formulaire.";
            return;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(client.MatriculeFiscale, MatriculePattern, System.Text.RegularExpressions.RegexOptions.IgnoreCase))
        {
            summaryIsError = true;
            summaryMessage = "Format matricule fiscale invalide. Exemple: 0000000/X/X/X000";
            return;
        }

        isSaving = true;
        try
        {
            if (isEditing && editingClientId.HasValue)
            {
                client.Id = editingClientId.Value;
                await ClientService.UpdateAsync(client);
                summaryMessage = "Client mis a jour avec succes.";
            }
            else
            {
                await ClientService.CreateAsync(client);
                summaryMessage = "Client créé avec succès.";
            }

            await LoadPageDataAsync();

            summaryIsError = false;
            HideForm();
            ResetForm();
        }
        catch (ValidationException ex)
        {
            summaryIsError = true;
            summaryMessage = ex.Message;
        }
        catch
        {
            summaryIsError = true;
            summaryMessage = isEditing
                ? "Une erreur est survenue lors de la mise a jour du client."
                : "Une erreur est survenue lors de la création du client.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private Client BuildClientFromForm()
    {
        var typeClient = formTypeClient switch
        {
            "Personne physique" => TypeClient.PersonnePhysique,
            "Personne morale" => TypeClient.PersonneMorale,
            _ => TypeClient.NonDefini
        };

        var statut = Enum.TryParse<StatutClient>(formStatut, true, out var parsedStatut)
            ? parsedStatut
            : StatutClient.Actif;

        FormeJuridique? formeJuridique = null;
        if (Enum.TryParse<FormeJuridique>(formFormeJuridique, true, out var parsedFormeJuridique))
        {
            formeJuridique = parsedFormeJuridique;
        }

        return new Client
        {
            TypeClient = typeClient,
            Statut = statut,
            CategorieClientId = null,
            Nom = (formNom ?? string.Empty).Trim(),
            MatriculeFiscale = (formMatriculeFiscale ?? string.Empty).Trim().ToUpperInvariant(),
            NumeroRne = NullIfWhiteSpace(formNumeroRne),
            FormeJuridique = formeJuridique,
            Adresse = NullIfWhiteSpace(formAdresse),
            CodePostal = NullIfWhiteSpace(formCodePostal),
            Ville = NullIfWhiteSpace(formVille),
            Gouvernorat = NullIfWhiteSpace(formGouvernorat),
            Pays = string.IsNullOrWhiteSpace(formPays) ? "Tunisie" : formPays.Trim(),
            Telephone = NullIfWhiteSpace(formTelephone),
            Telephone2 = NullIfWhiteSpace(formTelephone2),
            Fax = NullIfWhiteSpace(formFax),
            Email = NullIfWhiteSpace(formEmail),
            SiteWeb = NullIfWhiteSpace(formSiteWeb),
            NomContact = NullIfWhiteSpace(formNomContact),
            PosteContact = NullIfWhiteSpace(formPosteContact),
            PlafondCredit = formPlafondCredit,
            ModePaiement = ParseModePaiement(formModePaiement),
            Devise = string.IsNullOrWhiteSpace(formDevise) ? "TND" : formDevise.Trim(),
            RemiseParDefaut = formRemise,
            Notes = NullIfWhiteSpace(formNotes)
        };
    }

    private async Task<int?> ResolveSelectedCategoryIdAsync(string? selectedCategoryName)
    {
        if (string.IsNullOrWhiteSpace(selectedCategoryName))
        {
            return null;
        }

        var existing = categoriesClientDb
            .FirstOrDefault(c => string.Equals(c.Nom, selectedCategoryName, StringComparison.OrdinalIgnoreCase));

        if (existing is not null)
        {
            return existing.Id;
        }

        var created = await ClientService.CreateCategorieAsync(selectedCategoryName);
        categoriesClientDb.Add(created);
        categoriesClient = categoriesClientDb.Select(c => c.Nom).OrderBy(n => n).ToList();
        return created.Id;
    }

    private static string? NullIfWhiteSpace(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private static ModePaiement? ParseModePaiement(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return value.Trim() switch
        {
            "Virement" => ModePaiement.Virement,
            "Chèque" => ModePaiement.Cheque,
            "Cheque" => ModePaiement.Cheque,
            "Espèces" => ModePaiement.Especes,
            "Especes" => ModePaiement.Especes,
            "Traite" => ModePaiement.Traite,
            "Carte" => ModePaiement.CarteBancaire,
            "Carte bancaire" => ModePaiement.CarteBancaire,
            _ => null
        };
    }

    private static string GetStatusBadgeClass(StatutClient statut)
    {
        return statut switch
        {
            StatutClient.Actif => "bg-success-subtle text-success-emphasis",
            StatutClient.Inactif => "bg-secondary-subtle text-secondary-emphasis",
            StatutClient.Suspendu => "bg-warning-subtle text-warning-emphasis",
            _ => "bg-light text-dark"
        };
    }
