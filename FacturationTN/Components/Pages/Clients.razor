    private static string FormatMatriculeFiscale(string? rawValue)
    {
        if (string.IsNullOrWhiteSpace(rawValue))
        {
            return string.Empty;
        }

        var compact = new string(rawValue
            .Where(char.IsLetterOrDigit)
            .Select(char.ToUpperInvariant)
            .Take(13)
            .ToArray());

        if (compact.Length == 0)
        {
            return string.Empty;
        }

        var parts = new List<string>
        {
            compact[..Math.Min(7, compact.Length)]
        };

        if (compact.Length > 7)
        {
            parts.Add(compact[7].ToString());
        }

        if (compact.Length > 8)
        {
            parts.Add(compact[8].ToString());
        }

        if (compact.Length > 9)
        {
            parts.Add(compact[9..Math.Min(13, compact.Length)]);
        }

        return string.Join("/", parts);
    }

