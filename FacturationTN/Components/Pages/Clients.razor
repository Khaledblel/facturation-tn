@page "/clients"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using FacturationTN.Models
@using FacturationTN.Models.Enums
@using FacturationTN.Services.Interfaces
@inject IClientService ClientService
@inject NavigationManager NavigationManager

<PageTitle>Clients</PageTitle>

<div class="clients-shell">
<section class="clients-hero mb-4">
    <div class="clients-hero-inner">
        <div>
            <p class="clients-eyebrow mb-2">Espace clients</p>
            <h1 class="mb-2 clients-title">Gestion des clients</h1>
        </div>
        <div class="d-flex gap-2 flex-wrap justify-content-lg-end">
            <button class="btn btn-primary clients-modal-btn" @onclick="ShowCreateForm">
                <span class="me-1">+</span> Nouveau client
            </button>
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(summaryMessage))
{
    <div class="alert @(summaryIsError ? "alert-danger" : "alert-success") clients-alert" role="alert">
        @summaryMessage
    </div>
}

@* ── Search / Filter Bar ─────────────────────────────────────── *@
<div class="card border-0 shadow-sm clients-card mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            <div class="col-md-4">
                <div class="input-group input-group-sm clients-input-group">
                    <span class="input-group-text bg-white">
                        <svg class="clients-icon-search" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <circle cx="11" cy="11" r="6.5" stroke="currentColor" stroke-width="1.8"></circle>
                            <path d="M16 16L21 21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
                        </svg>
                    </span>
                    <input type="text" class="form-control" placeholder="Rechercher par nom, matricule, email..."
                              @bind="searchTerm" @bind:event="oninput" @bind:after="ApplyFilters" />
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <button class="btn btn-outline-secondary" @onclick="ClearSearch">✕</button>
                    }
                </div>
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" @bind="filterCategorie" @bind:after="ApplyFilters">
                    <option value="">Toutes catégories</option>
                    @foreach (var cat in categoriesClient)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" @bind="filterStatut" @bind:after="ApplyFilters">
                    <option value="">Tous statuts</option>
                    <option value="Actif">Actif</option>
                    <option value="Inactif">Inactif</option>
                    <option value="Suspendu">Suspendu</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" @bind="filterGouvernorat" @bind:after="ApplyFilters">
                    <option value="">Tous gouvernorats</option>
                    @foreach (var g in Gouvernorats)
                    {
                        <option value="@g">@g</option>
                    }
                </select>
            </div>
            <div class="col-md-2 text-end">
                <span class="clients-count-pill">@filteredCount client(s)</span>
            </div>
        </div>
    </div>
</div>

@* ── Client Table ─────────────────────────────────────────────── *@
<div class="card border-0 shadow-sm clients-card clients-table-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 clients-table">
                <thead>
                    <tr>
                        <th>Nom / Raison sociale</th>
                        <th>Téléphone</th>
                        <th>Email</th>
                        <th class="text-center">Catégorie</th>
                        <th class="text-center">Statut</th>
                        <th class="text-center" style="width: 260px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (filteredCount == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5 clients-empty-row">
                                @if (!string.IsNullOrEmpty(searchTerm))
                                {
                                    <span>Aucun client ne correspond à « @searchTerm »</span>
                                }
                                else
                                {
                                    <span>Aucun client enregistré. Cliquez sur <strong>Nouveau client</strong> pour commencer.</span>
                                }
                            </td>
                        </tr>
                    }
                    @foreach (var client in filteredClients)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@client.Nom</div>
                                <div class="text-muted small clients-break">@client.MatriculeFiscale</div>
                            </td>
                            <td class="clients-break">@(string.IsNullOrWhiteSpace(client.Telephone) ? "-" : client.Telephone)</td>
                            <td class="clients-break">@(string.IsNullOrWhiteSpace(client.Email) ? "-" : client.Email)</td>
                            <td class="text-center">@(client.Categorie?.Nom ?? "-")</td>
                            <td class="text-center">
                                <span class="badge @GetStatusBadgeClass(client.Statut)">@client.Statut</span>
                            </td>
                            <td class="text-center">
                                <div class="d-inline-flex gap-1">
                                    <a class="btn btn-sm clients-action-btn clients-action-view"
                                       title="Voir details"
                                       href="@($"/clients/{client.Id}")">
                                        <svg class="clients-action-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                            <circle cx="11" cy="11" r="6.5" stroke="currentColor" stroke-width="1.8"></circle>
                                            <path d="M16 16L21 21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
                                        </svg>
                                    </a>
                                    <button type="button"
                                            class="btn btn-sm clients-action-btn clients-action-edit"
                                            title="Modifier"
                                            @onclick="() => ShowEditForm(client)">
                                        <svg class="clients-action-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                            <path d="M4 20H8L18.5 9.5C19.1 8.9 19.1 7.9 18.5 7.3L16.7 5.5C16.1 4.9 15.1 4.9 14.5 5.5L4 16V20Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"></path>
                                        </svg>
                                        <span>Modifier</span>
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm clients-action-btn clients-action-delete"
                                            title="Supprimer"
                                            @onclick="() => ShowDeleteConfirmation(client)">
                                        <svg class="clients-action-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                            <path d="M5 7H19" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path>
                                            <path d="M9 7V5.8C9 5.36 9.36 5 9.8 5H14.2C14.64 5 15 5.36 15 5.8V7" stroke="currentColor" stroke-width="1.7"></path>
                                            <path d="M8 9.5V18C8 18.55 8.45 19 9 19H15C15.55 19 16 18.55 16 18V9.5" stroke="currentColor" stroke-width="1.7"></path>
                                        </svg>
                                        <span>Supprimer</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @* ── Pagination ────────────────────────────────────────────── *@
    <div class="card-footer bg-white d-flex justify-content-between align-items-center py-2 clients-footer">
        <span class="text-muted small">Affichage @currentStart–@currentEnd sur @filteredCount résultats</span>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item disabled"><a class="page-link" href="#">«</a></li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item disabled"><a class="page-link" href="#">»</a></li>
            </ul>
        </nav>
    </div>
</div>
</div>

@* ── Delete Confirmation Modal ───────────────────────────────── *@
@if (showDeleteConfirmation)
{
    <div class="modal fade show d-block clients-modal-backdrop" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered clients-delete-dialog">
            <div class="modal-content border-0 shadow clients-modal-content clients-danger-modal">
                <div class="modal-header clients-modal-header clients-danger-header">
                    <h5 class="modal-title clients-modal-title">Supprimer le client</h5>
                    <button type="button" class="btn-close" @onclick="HideDeleteConfirmation"></button>
                </div>
                <div class="modal-body clients-modal-body">
                    <p class="mb-2 small text-uppercase fw-semibold text-danger-emphasis">Action irreversible</p>
                    <p class="mb-0 text-break">
                        Voulez-vous vraiment supprimer
                        <strong class="d-inline-block w-100 mt-1 text-break">@clientToDeleteName</strong> ?
                    </p>
                </div>
                <div class="modal-footer clients-modal-footer">
                    <button type="button" class="btn btn-outline-secondary clients-modal-btn" @onclick="HideDeleteConfirmation" disabled="@isDeleting">
                        Annuler
                    </button>
                    <button type="button" class="btn btn-danger clients-modal-btn" @onclick="ConfirmDeleteClientAsync" disabled="@isDeleting">
                        @(isDeleting ? "Suppression..." : "Supprimer")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Delete Client Category Modal ───────────────────────────── *@
@if (showDeleteCategorieClientModal)
{
    <div class="modal fade show d-block clients-modal-backdrop" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 2000;">
        <div class="modal-dialog modal-dialog-centered clients-delete-dialog">
            <div class="modal-content border-0 shadow clients-modal-content">
                <div class="modal-header clients-modal-header">
                    <h5 class="modal-title clients-modal-title">Supprimer une catégorie client</h5>
                    <button type="button" class="btn-close" @onclick="HideDeleteCategorieClientModal"></button>
                </div>
                <div class="modal-body clients-modal-body">
                    <p class="text-muted mb-3">Seules les catégories personnalisées peuvent être supprimées.</p>

                    @if (!string.IsNullOrWhiteSpace(deleteCategorieClientMessage))
                    {
                        <div class="alert @(deleteCategorieClientIsError ? "alert-danger" : "alert-success") clients-modal-alert" role="alert">
                            @deleteCategorieClientMessage
                        </div>
                    }

                    @if (customCategoriesClient.Count == 0)
                    {
                        <div class="alert alert-light border mb-0">
                            Aucune catégorie personnalisée à supprimer.
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label">Catégorie personnalisée</label>
                            <select class="form-select" @bind="categorieClientToDeleteId">
                                <option value="">— Sélectionner —</option>
                                @foreach (var categorie in customCategoriesClient)
                                {
                                    <option value="@categorie.Id">@categorie.Nom (@GetCategorieClientUsageCount(categorie.Id) client(s))</option>
                                }
                            </select>
                            <div class="form-text">Les catégories liées à des clients ne peuvent pas être supprimées.</div>
                        </div>

                        @if (categorieClientToDeleteId.HasValue && GetCategorieClientUsageCount(categorieClientToDeleteId.Value) > 0)
                        {
                            <div class="alert alert-warning mb-0">
                                Cette catégorie est utilisée par @GetCategorieClientUsageCount(categorieClientToDeleteId.Value) client(s).
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer clients-modal-footer">
                    <button type="button" class="btn btn-outline-secondary clients-modal-btn" @onclick="HideDeleteCategorieClientModal" disabled="@isDeletingCategorieClient">
                        Fermer
                    </button>
                    <button type="button"
                            class="btn btn-danger clients-modal-btn"
                            @onclick="DeleteSelectedCategorieClientAsync"
                            disabled="@(isDeletingCategorieClient || !categorieClientToDeleteId.HasValue || GetCategorieClientUsageCount(categorieClientToDeleteId.Value) > 0)">
                        @(isDeletingCategorieClient ? "Suppression..." : "Supprimer")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Create / Edit Form (collapsible) ─────────────────────────── *@
@if (showForm)
{
    <div class="modal fade show d-block clients-modal-backdrop" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable clients-form-dialog">
            <div class="modal-content border-0 shadow clients-modal-content">
                <div class="modal-header clients-modal-header">
                    <h5 class="modal-title clients-modal-title">@(isEditing ? "Modifier le client" : "Nouveau client")</h5>
                    <button type="button" class="btn-close" @onclick="HideForm"></button>
                </div>
                <div class="modal-body clients-modal-body">

                    @if (showForm && summaryIsError && !string.IsNullOrWhiteSpace(summaryMessage))
                    {
                        <div class="alert alert-danger clients-modal-alert" role="alert">
                            @summaryMessage
                        </div>
                    }

                    @* ── Tabs ── *@
                    <ul class="nav nav-tabs mb-3 clients-form-tabs">
                        <li class="nav-item">
                            <button class="nav-link clients-tab-btn @(activeTab == 0 ? "active" : "")" @onclick="() => activeTab = 0">Identification</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link clients-tab-btn @(activeTab == 1 ? "active" : "")" @onclick="() => activeTab = 1">Adresse &amp; Contact</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link clients-tab-btn @(activeTab == 2 ? "active" : "")" @onclick="() => activeTab = 2">Commercial</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link clients-tab-btn @(activeTab == 3 ? "active" : "")" @onclick="() => activeTab = 3">Notes</button>
                        </li>
                    </ul>

                    @* ── Tab 0 : Identification ── *@
                    @if (activeTab == 0)
                    {
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Type de client <span class="text-danger">*</span></label>
                                <select class="form-select" @bind="formTypeClient">
                                    <option value="">— Sélectionner —</option>
                                    <option value="Personne physique">Personne physique</option>
                                    <option value="Personne morale">Personne morale</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Statut</label>
                                <select class="form-select" @bind="formStatut">
                                    <option value="Actif">Actif</option>
                                    <option value="Inactif">Inactif</option>
                                    <option value="Suspendu">Suspendu</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Catégorie</label>
                                @if (!showNewCategorieClient)
                                {
                                    <select class="form-select" value="@formCategorie"
                                            @onchange="OnFormCategorieClientChanged">
                                        <option value="">— Aucune —</option>
                                        @foreach (var cat in categoriesClient)
                                        {
                                            <option value="@cat">@cat</option>
                                        }
                                        <option disabled>────────────────</option>
                                        <option value="__new__">Créer une catégorie…</option>
                                        <option value="__delete__">Supprimer une catégorie…</option>
                                    </select>
                                }
                                else
                                {
                                    <div class="input-group">
                                        <input type="text" class="form-control" placeholder="Nouvelle catégorie"
                                                 maxlength="30"
                                               @bind="newCategorieClient" @bind:event="oninput" />
                                        <button class="btn btn-success btn-sm" type="button"
                                                disabled="@(string.IsNullOrWhiteSpace(newCategorieClient) || isCreatingCategory)"
                                                @onclick="AddCategorieClient">✓</button>
                                        <button class="btn btn-outline-secondary btn-sm" type="button"
                                                disabled="@isCreatingCategory"
                                                @onclick="CancelNewCategorieClient">✕</button>
                                    </div>
                                }
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Nom / Raison sociale <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" placeholder="Ex: Société ABC" maxlength="50" @bind="formNom" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Matricule fiscale <span class="text-danger">*</span></label>
                                <input type="text"
                                       class="form-control"
                                       placeholder="0000000/X/X/X000"
                                       maxlength="16"
                                       value="@formMatriculeFiscale"
                                       @oninput="OnMatriculeFiscaleInput" />
                                <div class="form-text">Format : 7 chiffres / lettre / lettre / lettre + 3 chiffres</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Numéro RNE</label>
                                <input type="text" class="form-control" placeholder="Ex: 1234567" maxlength="20" @bind="formNumeroRne" />
                                <div class="form-text">Registre National des Entreprises</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Forme juridique</label>
                                <select class="form-select" @bind="formFormeJuridique">
                                    <option value="">— Sélectionner —</option>
                                    <option value="EI">EI — Entreprise individuelle</option>
                                    <option value="SUARL">SUARL</option>
                                    <option value="SARL">SARL</option>
                                    <option value="SA">SA</option>
                                    <option value="Autre">Autre</option>
                                </select>
                            </div>
                        </div>
                    }

                    @* ── Tab 1 : Adresse & Contact ── *@
                    @if (activeTab == 1)
                    {
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Adresse</label>
                                <input type="text" class="form-control" placeholder="Numéro et nom de la rue" maxlength="50" @bind="formAdresse" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Code postal</label>
                                <input type="text" class="form-control" placeholder="Ex: 1000" maxlength="10" @bind="formCodePostal" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Ville</label>
                                <input type="text" class="form-control" placeholder="Ex: Tunis" maxlength="40" @bind="formVille" />
                            </div>
                            <div class="col-md-5">
                                <label class="form-label">Gouvernorat</label>
                                <select class="form-select" @bind="formGouvernorat">
                                    <option value="">— Sélectionner —</option>
                                    @foreach (var g in Gouvernorats)
                                    {
                                        <option value="@g">@g</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Pays</label>
                                <input type="text" class="form-control" placeholder="Tunisie" maxlength="30" @bind="formPays" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Téléphone</label>
                                <input type="tel" class="form-control" placeholder="+216 XX XXX XXX" maxlength="20" @bind="formTelephone" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Téléphone 2</label>
                                <input type="tel" class="form-control" placeholder="+216 XX XXX XXX" maxlength="20" @bind="formTelephone2" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Fax</label>
                                <input type="tel" class="form-control" placeholder="+216 XX XXX XXX" maxlength="20" @bind="formFax" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" placeholder="contact@exemple.tn" maxlength="50" @bind="formEmail" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Site web</label>
                                <input type="text" class="form-control" placeholder="https://exemple.tn" maxlength="50" @bind="formSiteWeb" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Nom du contact principal</label>
                                <input type="text" class="form-control" placeholder="Prénom Nom" maxlength="50" @bind="formNomContact" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Poste du contact</label>
                                <input type="text" class="form-control" placeholder="Ex: Directeur financier" maxlength="50" @bind="formPosteContact" />
                            </div>
                        </div>
                    }

                    @* ── Tab 2 : Commercial ── *@
                    @if (activeTab == 2)
                    {
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Plafond de crédit</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" step="0.001" min="0"
                                           placeholder="0.000" @bind="formPlafondCredit" />
                                    <span class="input-group-text">@(string.IsNullOrWhiteSpace(formDevise) ? "TND" : formDevise)</span>
                                </div>
                                <div class="form-text">0 = pas de limite</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Mode de paiement préféré</label>
                                <select class="form-select" @bind="formModePaiement">
                                    <option value="">— Sélectionner —</option>
                                    <option value="Virement">Virement bancaire</option>
                                    <option value="Chèque">Chèque</option>
                                    <option value="Espèces">Espèces</option>
                                    <option value="Traite">Traite</option>
                                    <option value="Carte">Carte bancaire</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Devise</label>
                                <select class="form-select" @bind="formDevise">
                                    <option value="TND">TND — Dinar tunisien</option>
                                    <option value="EUR">EUR — Euro</option>
                                    <option value="USD">USD — Dollar américain</option>
                                    <option value="GBP">GBP — Livre sterling</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Remise par défaut</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" step="0.01" min="0" max="100"
                                           placeholder="0.00" @bind="formRemise" />
                                    <span class="input-group-text">%</span>
                                </div>
                                <div class="form-text">Appliquée automatiquement aux lignes de facture</div>
                            </div>
                        </div>
                    }

                    @* ── Tab 3 : Notes ── *@
                    @if (activeTab == 3)
                    {
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Notes / Observations</label>
                                <textarea class="form-control" rows="6"
                                          maxlength="2000"
                                          placeholder="Remarques internes, informations complémentaires..."
                                          @bind="formNotes"></textarea>
                                <div class="form-text">Visible uniquement en interne — n'apparaît pas sur les factures.</div>
                            </div>
                        </div>
                    }

                </div>
                <div class="modal-footer clients-modal-footer">
                    <button type="button" class="btn btn-outline-secondary clients-modal-btn" @onclick="HideForm">Annuler</button>
                    <button type="button" class="btn btn-primary clients-modal-btn" @onclick="SaveClient" disabled="@isSaving">
                        @(isSaving ? "Enregistrement..." : isEditing ? "Mettre a jour" : "Enregistrer")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "editId")]
    public int? EditId { get; set; }

    private const string MatriculePattern = @"^\d{7}/[A-Z]/[A-Z]/[A-Z]\d{3}$";

    // ── Search & filter state ──
    private string searchTerm = string.Empty;
    private string filterCategorie = string.Empty;
