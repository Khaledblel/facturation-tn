    }

    private async Task DeleteSelectedCategorieClientAsync()
    {
        if (isDeletingCategorieClient || !categorieClientToDeleteId.HasValue)
        {
            return;
        }

        if (GetCategorieClientUsageCount(categorieClientToDeleteId.Value) > 0)
        {
            deleteCategorieClientIsError = true;
            deleteCategorieClientMessage = "Impossible de supprimer cette categorie car elle est utilisee par au moins un client.";
            return;
        }

        isDeletingCategorieClient = true;
        try
        {
            var categorieId = categorieClientToDeleteId.Value;
            var deletedCategory = categoriesClientDb.FirstOrDefault(c => c.Id == categorieId);
            var deletedCategoryName = deletedCategory?.Nom;

            await ClientService.DeleteCategorieAsync(categorieId);
            await LoadPageDataAsync();

            if (!string.IsNullOrWhiteSpace(deletedCategoryName) &&
                string.Equals(formCategorie, deletedCategoryName, StringComparison.OrdinalIgnoreCase))
            {
                formCategorie = string.Empty;
            }

            summaryIsError = false;
            summaryMessage = "Categorie client supprimee avec succes.";
            HideDeleteCategorieClientModal();
        }
        catch (ValidationException ex)
        {
            deleteCategorieClientIsError = true;
            deleteCategorieClientMessage = ex.Message;
        }
        catch (InvalidOperationException ex)
        {
            deleteCategorieClientIsError = true;
            deleteCategorieClientMessage = ex.Message;
        }
        catch (KeyNotFoundException ex)
        {
            deleteCategorieClientIsError = true;
            deleteCategorieClientMessage = ex.Message;
        }
        catch
        {
            deleteCategorieClientIsError = true;
            deleteCategorieClientMessage = "Impossible de supprimer la categorie pour le moment.";
        }
        finally
        {
            isDeletingCategorieClient = false;
        }
    }

